# Backend environment template for local development
# Copy this file to .env and update values as needed.

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/karyon_data
# Optional: force the app to use an embedded MongoDB instance for demo/shared-zip usage
# USE_EMBEDDED_DB=true
# Optional embedded DB name
# EMBEDDED_DB_NAME=karyon_demo
# Optional: seed demo users/bookings/chats on first startup (auto-on in embedded mode)
# SEED_DEMO=true

# Auth
JWT_SECRET=6b1b08889709482bba957e88306c0c232c7b4b44bcdadba3f43b777314e4f815a78d46d1a7c998be425efce631be1ffda8ce76ed99948c885d96584fd6328f87
JWT_EXPIRE=7d

# Server
PORT=5001
NODE_ENV=development

# Frontend URL used in password reset links
FRONTEND_URL=http://localhost:5173

# Optional: set to true to boot API without DB connection in development
# SKIP_DB=true

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# Email (optional, used for forgot-password and contact-form notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=shekharsidhant88@gmail.com
EMAIL_PASS=chkl vcxg kvsx ebth
# Optional: where contact form submissions should be delivered.
# If omitted, EMAIL_USER is used.
CONTACT_RECEIVER_EMAIL=shekharsidhant88@gmail.com

# Twilio (optional, OTP currently logged in dev)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
